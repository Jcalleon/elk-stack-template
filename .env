# =============================================================================
# ELK Stack environment configuration
# Copy to .env.local and edit before first run, or override at deploy time.
# =============================================================================

# ---- Version -----------------------------------------------------------
STACK_VERSION=8.15.3
ES_CLUSTER_NAME=elk-cluster
LICENSE=basic

# ---- Built-in user passwords (CHANGE THESE) -----------------------------
ELASTIC_PASSWORD=ChangeMe_Elastic!
KIBANA_PASSWORD=ChangeMe_Kibana!
LOGSTASH_INTERNAL_PASSWORD=ChangeMe_Logstash!
FILEBEAT_INTERNAL_PASSWORD=ChangeMe_Filebeat!

# Kibana requires a 32+ char random string. Generate with:
#   openssl rand -hex 32
KIBANA_ENCRYPTION_KEY=please_generate_a_32_char_min_random_string_here

# ---- Host port mappings --------------------------------------------------
# Only Kibana is exposed to the host by default; ES/Logstash stay on the
# private network. Uncomment ES_PORT/LOGSTASH_PORT lines in docker-compose.yml
# if you need host access for debugging.
KIBANA_PORT=5601
ES_PORT=9200
LOGSTASH_BEATS_PORT=5044

# ---- Memory limits (bytes) ------------------------------------------------
ES_MEM_LIMIT=1073741824
LS_MEM_LIMIT=1073741824
KB_MEM_LIMIT=1073741824
